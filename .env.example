# Anthropic (Claude Vision for synth identification)
ANTHROPIC_API_KEY=sk-ant-...

# Reverb API (listing management)
REVERB_API_TOKEN=your-reverb-token
# Use sandbox for testing: https://sandbox.reverb.com
REVERB_BASE_URL=https://api.reverb.com/api

# Cloudflare R2 (image hosting)
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=synthshop
R2_PUBLIC_URL=https://your-r2-public-url.com

# Stripe (direct payments)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Shop website
SHOP_BASE_URL=https://shop.bounceconnectionrecords.com
